#!/usr/bin/env python3
"""
LearnAgent CLI 启动脚本

用法:
    learn-agent              # 启动交互式 Agent
    learn-agent --help       # 显示帮助
"""

import sys
from pathlib import Path

# 确保使用正确的路径
project_root = Path(__file__).parent.parent / "src"
sys.path.insert(0, str(project_root))

try:
    from learn_agent.core.main import main
    main()
except ImportError as e:
    print(f"Error: Cannot import learn_agent module: {e}")
    print("\nMake sure you've installed the package:")
    print("  pip install -e .")
    sys.exit(1)
except Exception as e:
    print(f"Error: {e}")
    sys.exit(1)
